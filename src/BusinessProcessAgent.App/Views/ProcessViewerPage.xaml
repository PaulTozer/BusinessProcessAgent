<?xml version="1.0" encoding="UTF-8" ?>
<Page
    x:Class="BusinessProcessAgent.App.Views.ProcessViewerPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Loaded="OnLoaded">

    <Grid Padding="24" RowSpacing="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header with back button -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="12">
            <Button Content="← Back" Click="OnBack"/>
            <TextBlock Text="Discovered Business Processes" FontSize="22"
                       FontWeight="SemiBold" VerticalAlignment="Center"/>
        </StackPanel>

        <!-- Two-pane layout: process list + step details -->
        <Grid Grid.Row="1" ColumnSpacing="16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="300"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Process list -->
            <ListView x:Name="processList" Grid.Column="0"
                      SelectionChanged="OnProcessSelected">
                <ListView.ItemTemplate>
                    <DataTemplate>
                        <StackPanel Padding="8,6" Spacing="4">
                            <TextBlock Text="{Binding Name}" FontWeight="SemiBold"
                                       TextTrimming="CharacterEllipsis"/>
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <TextBlock FontSize="12"
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}">
                                    <Run Text="{Binding StepCount}"/>
                                    <Run Text="steps"/>
                                </TextBlock>
                            </StackPanel>
                        </StackPanel>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>

            <!-- Step details -->
            <ScrollViewer Grid.Column="1">
                <ListView x:Name="stepList" SelectionMode="None">
                    <ListView.ItemTemplate>
                        <DataTemplate>
                            <Grid Padding="12,8" ColumnSpacing="16" RowSpacing="4">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="40"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <!-- Step number badge -->
                                <Border Grid.Column="0" Grid.RowSpan="4"
                                        Background="{StaticResource PrimaryBrush}"
                                        CornerRadius="20" Width="36" Height="36"
                                        HorizontalAlignment="Center" VerticalAlignment="Top">
                                    <TextBlock Text="{Binding StepNumber}"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"
                                               Foreground="White" FontWeight="Bold"/>
                                </Border>

                                <!-- High-level action -->
                                <TextBlock Grid.Column="1" Grid.Row="0"
                                           Text="{Binding HighLevelAction}"
                                           FontWeight="SemiBold" TextWrapping="Wrap"/>

                                <!-- Low-level action -->
                                <TextBlock Grid.Column="1" Grid.Row="1"
                                           Text="{Binding LowLevelAction}"
                                           FontSize="13"
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                           TextWrapping="Wrap"/>

                                <!-- User intent -->
                                <StackPanel Grid.Column="1" Grid.Row="2"
                                            Orientation="Horizontal" Spacing="6">
                                    <FontIcon Glyph="&#xE946;" FontSize="12"/>
                                    <TextBlock Text="{Binding UserIntent}" FontSize="12"
                                               FontStyle="Italic"
                                               Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                                               TextWrapping="Wrap"/>
                                </StackPanel>

                                <!-- Application + timestamp -->
                                <StackPanel Grid.Column="1" Grid.Row="3"
                                            Orientation="Horizontal" Spacing="12">
                                    <TextBlock FontSize="11"
                                               Foreground="{ThemeResource TextFillColorTertiaryBrush}">
                                        <Run Text="{Binding ApplicationName}"/>
                                    </TextBlock>
                                    <TextBlock FontSize="11"
                                               Foreground="{ThemeResource TextFillColorTertiaryBrush}">
                                        <Run Text="{Binding Timestamp}"/>
                                    </TextBlock>
                                </StackPanel>
                            </Grid>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </ScrollViewer>
        </Grid>
    </Grid>
</Page>
